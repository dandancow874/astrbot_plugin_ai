  "Image-to-Prompt": {
    "description": "Image-to-Prompt 模型配置",
    "type": "object",
    "hint": "反推会使用这里配置的 URL 与 API Key。",
    "items": {
      "enabled": {
        "description": "启用",
        "type": "bool",
        "default": true
      },
      "model": {
        "description": "模型名称",
        "type": "string",
        "default": ""
      },
      "system_prompt": {
        "description": "系统提示词",
        "type": "string",
        "default": ""
      },
      "primary": {
        "description": "主提供商",
        "type": "object",
        "items": {
          "api_url": {
            "description": "OpenAI 兼容 URL",
            "type": "string",
            "default": "https://api.openai.com/v1",
            "hint": "填 Base URL。"
          },
          "api_key": {
            "description": "API Key",
            "type": "string",
            "default": "",
            "hint": "直接粘贴 Key。多个 Key 可用英文逗号或换行分隔。"
          },
          "tls_verify": {
            "description": "TLS 证书验证",
            "type": "bool",
            "default": true
          },
          "impersonate": {
            "description": "TLS/UA 指纹伪装",
            "type": "string",
            "default": "chrome131"
          }
        }
      }
    }
  },
  "prompt_config": {
    "description": "提示词默认参数",
    "type": "object",
    "hint": "",
    "items": {
      "min_images": {
        "description": "最小输入图片数量",
        "type": "int",
        "default": 1
      },
      "max_images": {
        "description": "最大输入图片数量",
        "type": "int",
        "default": 6
      },
      "aspect_ratio": {
        "description": "宽高比",
        "type": "string",
        "options": [
          "default",
          "1:1",
          "2:3",
          "3:2",
          "3:4",
          "4:3",
          "9:16",
          "16:9"
        ],
        "default": "default"
      },
      "image_size": {
        "description": "分辨率",
        "type": "string",
        "options": [
          "1K",
          "2K",
          "4K"
        ],
        "default": "1K"
      },
      "google_search": {
        "description": "是否启用谷歌搜索工具",
        "type": "bool",
        "default": true
      },
      "refer_images": {
        "description": "参考图片",
        "type": "string",
        "default": ""
      },
      "gather_mode": {
        "description": "启用收集模式",
        "type": "bool",
        "default": false
      }
    }
  },
  "common_config": {
    "description": "常规配置",
    "type": "object",
    "hint": "",
    "items": {
      "preset_append": {
        "description": "启用预设提示词补充",
        "type": "bool",
        "default": true
      },
      "text_response": {
        "description": "启用文本响应",
        "type": "bool",
        "default": false
      },
      "smart_retry": {
        "description": "启用智能重试",
        "type": "bool",
        "default": true
      },
      "max_retry": {
        "description": "最大重试次数",
        "type": "int",
        "default": 3
      },
      "timeout": {
        "description": "超时",
        "type": "float",
        "default": 300
      },
      "proxy": {
        "description": "HTTP 代理",
        "type": "string",
        "default": ""
      }
    }
  },
  "prefix_config": {
    "description": "绘图命令触发方式",
    "type": "object",
    "hint": "",
    "items": {
      "coexist_enabled": {
        "description": "混合模式",
        "type": "bool",
        "default": false
      },
      "prefix_list": {
        "description": "命令前缀",
        "type": "list",
        "default": []
      }
    }
  },
  "preference_config": {
    "description": "偏好设置",
    "type": "object",
    "hint": "以下配置因个人使用需求而异。跳过 At 头像的三个选项共用一个计数。",
    "items": {
      "skip_at_first": {
        "description": "跳过第一次@机器人",
        "type": "bool",
        "default": true
      },
      "skip_quote_first": {
        "description": "跳过第一次@引用",
        "type": "bool",
        "default": true
      },
      "skip_llm_at_first": {
        "description": "LLM 跳过第一次@机器人",
        "type": "bool",
        "default": true
      }
    }
  },
  "llm_tool_settings": {
    "description": "LLM 函数调用工具配置",
    "type": "object",
    "hint": "",
    "items": {
      "llm_tool_enabled": {
        "description": "启用函数调用工具",
        "type": "bool",
        "default": true
      }
    }
  },
  "save_images": {
    "description": "图片存储",
    "type": "object",
    "hint": "",
    "items": {
      "local_save": {
        "description": "本地存储",
        "type": "bool",
        "default": false
      }
    }
  },
  "whitelist_config": {
    "description": "白名单配置",
    "type": "object",
    "hint": "",
    "items": {
      "enabled": {
        "description": "启用群组白名单",
        "type": "bool",
        "default": false
      },
      "whitelist": {
        "description": "群组 UMO 白名单",
        "type": "list",
        "default": []
      },
      "user_enabled": {
        "description": "启用用户白名单",
        "type": "bool",
        "default": false
      },
      "user_whitelist": {
        "description": "用户 ID 白名单",
        "type": "list",
        "default": []
      }
    }
  }
}
