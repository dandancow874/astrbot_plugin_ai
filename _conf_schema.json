{
    "prompt": {
        "description": "预设提示词",
        "type": "list",
        "default": [
            "反推 详细描述这张图片 --min_images 1"
        ],
        "hint": "只保留反推命令。"
    },
    "providers": {
        "description": "🔌 AI 服务商配置",
        "type": "list",
        "hint": "服务商列表，优先级数值越小越优先。",
        "items": {
            "name": {
                "description": "服务商名称",
                "type": "string",
                "default": "新服务商"
            },
            "enabled": {
                "description": "启用",
                "type": "bool",
                "default": true
            },
            "priority": {
                "description": "优先级",
                "type": "int",
                "default": 0
            },
            "base_url": {
                "description": "Base URL",
                "type": "string",
                "default": "",
                "hint": "例如 https://grsai.ai 或 https://ai.gitee.com/v1"
            },
            "api_key": {
                "description": "API Key",
                "type": "string",
                "default": ""
            },
            "api_type": {
                "description": "API 类型",
                "type": "string",
                "options": ["OpenAI_Chat", "OpenAI_Images", "Gemini", "Vertex_AI_Anonymous"],
                "default": "OpenAI_Chat"
            },
            "tls_verify": {
                "description": "TLS 证书验证",
                "type": "bool",
                "default": true
            },
            "impersonate": {
                "description": "TLS/UA 指纹伪装",
                "type": "string",
                "default": "chrome131"
            },
            "models": {
                "description": "模型配置",
                "type": "string",
                "default": "",
                "hint": "JSON格式：[{\"model_name\":\"nano-banana-pro\",\"triggers\":[\"bn2\"]},{\"model_name\":\"z-image-turbo\",\"triggers\":[\"zi\"]}]"
            }
        },
        "default": [
            {
                "name": "grsai",
                "enabled": true,
                "priority": 0,
                "base_url": "https://grsai.ai",
                "api_key": "sk-da2e418bb5474bff952c9f4579c5b4e0",
                "api_type": "OpenAI_Chat",
                "tls_verify": true,
                "impersonate": "chrome131",
                "models": "[{\"model_name\":\"nano-banana-pro\",\"triggers\":[\"bn2\"]}]"
            },
            {
                "name": "gite",
                "enabled": true,
                "priority": 1,
                "base_url": "https://ai.gitee.com/v1",
                "api_key": "P7VWNFGGTW4TFSLHZEERAPOVC8TTJZ3JMSPKOK1L",
                "api_type": "OpenAI_Images",
                "tls_verify": true,
                "impersonate": "chrome131",
                "models": "[{\"model_name\":\"z-image-turbo\",\"triggers\":[\"zi\"]}]"
            }
        ]
    },
    "Image-to-Prompt": {
        "description": "🧪 Image-to-Prompt 模型配置",
        "type": "object",
        "hint": "反推 会使用这里配置的 URL 与 API Key。",
        "items": {
            "enabled": {
                "description": "启用",
                "type": "bool",
                "default": true
            },
            "model": {
                "description": "模型名称",
                "type": "string",
                "default": "",
                "hint": "可留空（让接口使用默认模型）。如果接口提示 Model does not exist，请在这里填对方支持的模型名。"
            },
            "system_prompt": {
                "description": "系统提示词",
                "type": "string",
                "default": "",
                "hint": "可留空。会作为 system 消息发送。"
            },
            "primary": {
                "description": "主提供商",
                "type": "object",
                "items": {
                    "api_url": {
                        "description": "OpenAI兼容 URL",
                        "type": "string",
                        "default": "https://api.openai.com/v1",
                        "hint": "填 Base URL。"
                    },
                    "api_key": {
                        "description": "API Key",
                        "type": "string",
                        "default": "",
                        "hint": "直接粘贴 Key。多个 Key 可用英文逗号或换行分隔。"
                    },
                    "tls_verify": {
                        "description": "TLS证书验证",
                        "type": "bool",
                        "default": true
                    },
                    "impersonate": {
                        "description": "TLS/UA 指纹伪装",
                        "type": "string",
                        "default": "chrome131"
                    }
                }
            }
        }
    },
    "prompt_config": {
        "description": "提示词默认参数",
        "type": "object",
        "hint": "若提示词中未指定参数，将使用这里的默认参数。",
        "items": {
            "min_images": {
                "description": "最小输入图片数量",
                "type": "int",
                "default": 1,
                "hint": "如果消息携带的图片数量少于这个值，将自动添加At对象头像。"
            },
            "max_images": {
                "description": "最大输入图片数量",
                "type": "int",
                "default": 6,
                "hint": "消息中携带的图片数量超过这个值n，只取前n张图片。"
            },
            "aspect_ratio": {
                "description": "宽高比",
                "type": "string",
                "options": [
                    "default",
                    "1:1",
                    "2:3",
                    "3:2",
                    "3:4",
                    "4:3",
                    "9:16",
                    "16:9"
                ],
                "default": "default"
            },
            "image_size": {
                "description": "分辨率",
                "type": "string",
                "options": [
                    "1K",
                    "2K",
                    "4K"
                ],
                "default": "1K"
            },
            "google_search": {
                "description": "是否启用谷歌搜索工具",
                "type": "bool",
                "default": true
            },
            "refer_images": {
                "description": "参考图片",
                "type": "string",
                "default": "",
                "hint": "填写格式是 文件名1,文件名2 把图片文件放在插件数据目录的 refer_images 文件夹下。"
            },
            "gather_mode": {
                "description": "启用收集模式",
                "type": "bool",
                "default": false
            }
        }
    },
    "common_config": {
        "description": "常规配置",
        "type": "object",
        "hint": "",
        "items": {
            "preset_append": {
                "description": "启用预设提示词补充",
                "type": "bool",
                "default": true
            },
            "text_response": {
                "description": "启用文本响应",
                "type": "bool",
                "default": false
            },
            "smart_retry": {
                "description": "启用智能重试",
                "type": "bool",
                "default": true
            },
            "max_retry": {
                "description": "最大重试次数",
                "type": "int",
                "default": 3
            },
            "timeout": {
                "description": "超时",
                "type": "float",
                "default": 300
            },
            "proxy": {
                "description": "HTTP代理",
                "type": "string",
                "default": ""
            }
        }
    },
    "prefix_config": {
        "description": "绘图命令触发方式",
        "type": "object",
        "hint": "默认情况下，@机器人 将无视前缀要求。",
        "items": {
            "coexist_enabled": {
                "description": "混合模式",
                "type": "bool",
                "default": false
            },
            "prefix_list": {
                "description": "命令前缀",
                "type": "list",
                "default": []
            }
        }
    },
    "vertex_ai_anonymous_config": {
        "description": "Vertex AI Anonymous配置项",
        "type": "object",
        "hint": "提供商配置中，除了接口规范和模型外，其他选项皆对Vertex AI Anonymous规范无效，请在此配置。",
        "items": {
            "recaptcha_base_api": {
                "description": "Recaptcha Base API",
                "type": "string",
                "default": "https://www.google.com"
            },
            "vertex_ai_anonymous_base_api": {
                "description": "Vertex AI Anonymous Base API",
                "type": "string",
                "default": "https://cloudconsole-pa.clients6.google.com"
            },
            "tls_verify": {
                "description": "TLS证书校验",
                "type": "bool",
                "default": true
            },
            "system_prompt": {
                "description": "系统提示词",
                "type": "text",
                "default": ""
            },
            "max_retry": {
                "description": "最大重试次数",
                "type": "int",
                "default": 10
            }
        }
    },
    "preference_config": {
        "description": "偏好设置",
        "type": "object",
        "hint": "以下配置因个人使用需求而异，暂无两全之策。跳过At头像的三个选项共用一个计数。",
        "items": {
            "skip_at_first": {
                "description": "跳过第一次@机器人",
                "type": "bool",
                "default": true
            },
            "skip_quote_first": {
                "description": "跳过第一次@引用",
                "type": "bool",
                "default": true
            },
            "skip_llm_at_first": {
                "description": "LLM跳过第一次@机器人",
                "type": "bool",
                "default": true
            }
        }
    },
    "llm_tool_settings": {
        "description": "LLM函数调用工具配置",
        "type": "object",
        "hint": "",
        "items": {
            "llm_tool_enabled": {
                "description": "启用函数调用工具",
                "type": "bool",
                "default": true
            }
        }
    },
    "save_images": {
        "description": "图片存储",
        "type": "object",
        "hint": "",
        "items": {
            "local_save": {
                "description": "本地存储",
                "type": "bool",
                "default": false
            }
        }
    },
    "whitelist_config": {
        "description": "白名单配置",
        "type": "object",
        "hint": "",
        "items": {
            "enabled": {
                "description": "启用群组白名单",
                "type": "bool",
                "default": false
            },
            "whitelist": {
                "description": "群组UMO白名单",
                "type": "list",
                "default": []
            },
            "user_enabled": {
                "description": "启用用户白名单",
                "type": "bool",
                "default": false
            },
            "user_whitelist": {
                "description": "用户ID白名单",
                "type": "list",
                "default": []
            }
        }
    }
}
